generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TipoUsuario {
  artista
  contratante
}

enum StatusProposta {
  pendente
  aceita
  recusada
  cancelada
}

// Better Auth core models
model User {
  id            String      @id @default(cuid())
  name          String
  email         String      @unique
  emailVerified Boolean     @default(false)
  image         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Domain-specific fields
  tipo_usuario   TipoUsuario?
  telefone       String?
  descricao      String?
  cidade         String?
  estado         String?
  genero_musical String?
  preco_minimo   Decimal?    @db.Decimal(10, 2)
  preco_maximo   Decimal?    @db.Decimal(10, 2)
  portfolio      String[]
  spotify_url    String?
  instagram_url  String?
  youtube_url    String?
  cor_tema       String?
  cor_banner     String?

  sessions             Session[]
  accounts             Account[]
  propostas_enviadas   Proposta[]  @relation("Contratante")
  propostas_recebidas  Proposta[]  @relation("Artista")
  avaliacoes_feitas    Avaliacao[] @relation("Avaliador")
  avaliacoes_recebidas Avaliacao[] @relation("Avaliado")

  @@index([email])
  @@index([tipo_usuario])
  @@index([genero_musical])
  @@index([cidade])
  @@index([estado])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model Proposta {
  id_proposta         Int            @id @default(autoincrement())
  id_contratante      String
  id_artista          String
  titulo              String
  descricao           String
  data_evento         DateTime       @db.Date
  hora_evento         DateTime?      @db.Time
  local_evento        String
  endereco_completo   String?
  tipo_evento         String?
  duracao_horas       Decimal?       @db.Decimal(3, 1)
  publico_esperado    Int?
  equipamento_incluso Boolean        @default(false)
  nome_responsavel    String?
  telefone_contato    String?
  observacoes         String?
  valor_oferecido     Decimal        @db.Decimal(10, 2)
  status              StatusProposta @default(pendente)
  mensagem_resposta   String?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  contratante User @relation("Contratante", fields: [id_contratante], references: [id], onDelete: Cascade)
  artista     User @relation("Artista", fields: [id_artista], references: [id], onDelete: Cascade)

  @@index([id_contratante])
  @@index([id_artista])
  @@index([status])
  @@index([data_evento])
  @@map("propostas")
}

model Avaliacao {
  id_avaliacao Int      @id @default(autoincrement())
  id_avaliador String
  id_avaliado  String
  nota         Int
  comentario   String?
  created_at   DateTime @default(now())

  avaliador User @relation("Avaliador", fields: [id_avaliador], references: [id], onDelete: Cascade)
  avaliado  User @relation("Avaliado", fields: [id_avaliado], references: [id], onDelete: Cascade)

  @@unique([id_avaliador, id_avaliado])
  @@index([id_avaliado])
  @@index([id_avaliador])
  @@map("avaliacoes")
}
