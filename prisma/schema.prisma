generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TipoUsuario {
  artista
  contratante
}

enum StatusProposta {
  pendente
  aceita
  recusada
  cancelada
}

enum TipoPost {
  post
  disponibilidade
  buscando
}

enum VisibilidadePost {
  publico
  seguidores
  privado
}

enum TipoMidia {
  imagem
  video
}

// Better Auth core models
model User {
  id            String      @id @default(cuid())
  name          String      @db.VarChar(100)
  email         String      @unique
  emailVerified Boolean     @default(false)
  image         String?     @db.VarChar(500)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Domain-specific fields
  tipo_usuario   TipoUsuario?
  telefone       String      @default("") @db.VarChar(20)
  descricao      String      @default("") @db.VarChar(1000)
  cidade         String      @default("") @db.VarChar(100)
  estado         String      @default("") @db.VarChar(2)
  genero_musical String?
  preco_minimo   Decimal?    @db.Decimal(10, 2)
  preco_maximo   Decimal?    @db.Decimal(10, 2)
  portfolio      String[]    @default([])
  spotify_url    String?
  instagram_url  String?
  youtube_url    String?
  cor_tema       String?
  cor_banner     String?

  sessions             Session[]
  accounts             Account[]
  propostas_enviadas   Proposta[]  @relation("Contratante")
  propostas_recebidas  Proposta[]  @relation("Artista")
  avaliacoes_feitas    Avaliacao[] @relation("Avaliador")
  avaliacoes_recebidas Avaliacao[] @relation("Avaliado")
  posts                Post[]        @relation("PostsDoUsuario")
  curtidas             Curtida[]     @relation("CurtidasDoUsuario")
  comentarios          Comentario[]  @relation("ComentariosDoUsuario")
  stories              Story[]       @relation("StoriesDoUsuario")
  story_views          StoryView[]   @relation("ViewsDoUsuario")
  visitas_feitas       VisitaPerfil[] @relation("VisitasFeitas")
  visitas_recebidas    VisitaPerfil[] @relation("VisitasRecebidas")

  @@index([email])
  @@index([tipo_usuario])
  @@index([genero_musical])
  @@index([cidade])
  @@index([estado])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model Proposta {
  id_proposta         Int            @id @default(autoincrement())
  id_contratante      String
  id_artista          String
  titulo              String
  descricao           String
  data_evento         DateTime       @db.Date
  hora_evento         DateTime?      @db.Time
  local_evento        String
  endereco_completo   String?
  tipo_evento         String?
  duracao_horas       Decimal?       @db.Decimal(3, 1)
  publico_esperado    Int?
  equipamento_incluso Boolean        @default(false)
  nome_responsavel    String?
  telefone_contato    String?
  observacoes         String?
  valor_oferecido     Decimal        @db.Decimal(10, 2)
  status              StatusProposta @default(pendente)
  mensagem_resposta   String?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  contratante User @relation("Contratante", fields: [id_contratante], references: [id], onDelete: Cascade)
  artista     User @relation("Artista", fields: [id_artista], references: [id], onDelete: Cascade)

  @@index([id_contratante])
  @@index([id_artista])
  @@index([status])
  @@index([data_evento])
  @@map("propostas")
}

model Avaliacao {
  id_avaliacao Int      @id @default(autoincrement())
  id_avaliador String
  id_avaliado  String
  nota         Int
  comentario   String?
  created_at   DateTime @default(now())

  avaliador User @relation("Avaliador", fields: [id_avaliador], references: [id], onDelete: Cascade)
  avaliado  User @relation("Avaliado", fields: [id_avaliado], references: [id], onDelete: Cascade)

  @@unique([id_avaliador, id_avaliado])
  @@index([id_avaliado])
  @@index([id_avaliador])
  @@map("avaliacoes")
}

model VisitaPerfil {
  id_visita    Int      @id @default(autoincrement())
  id_visitante String?
  id_artista   String
  created_at   DateTime @default(now())

  visitante    User?    @relation("VisitasFeitas", fields: [id_visitante], references: [id], onDelete: SetNull)
  artista      User     @relation("VisitasRecebidas", fields: [id_artista], references: [id], onDelete: Cascade)

  @@index([id_artista])
  @@index([created_at])
  @@map("visitas_perfil")
}


// ── Feed System ──

model Post {
  id                String           @id @default(cuid())
  id_autor          String
  conteudo          String
  tipo              TipoPost         @default(post)
  visibilidade      VisibilidadePost @default(publico)
  imagens           String[]
  video_url         String?
  tags              String[]
  cidade            String?
  estado            String?
  curtidas_count    Int              @default(0)
  comentarios_count Int              @default(0)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  autor       User         @relation("PostsDoUsuario", fields: [id_autor], references: [id], onDelete: Cascade)
  curtidas    Curtida[]
  comentarios Comentario[]

  @@index([id_autor])
  @@index([tipo])
  @@index([visibilidade])
  @@index([cidade])
  @@index([estado])
  @@index([created_at(sort: Desc)])
  @@index([id_autor, created_at(sort: Desc)])
  @@map("posts")
}

model Curtida {
  id         String   @id @default(cuid())
  id_usuario String
  id_post    String
  created_at DateTime @default(now())

  usuario User @relation("CurtidasDoUsuario", fields: [id_usuario], references: [id], onDelete: Cascade)
  post    Post @relation(fields: [id_post], references: [id], onDelete: Cascade)

  @@unique([id_usuario, id_post])
  @@index([id_post])
  @@index([id_usuario])
  @@map("curtidas")
}

model Comentario {
  id                String   @id @default(cuid())
  id_autor          String
  id_post           String
  id_comentario_pai String?
  conteudo          String
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  autor          User         @relation("ComentariosDoUsuario", fields: [id_autor], references: [id], onDelete: Cascade)
  post           Post         @relation(fields: [id_post], references: [id], onDelete: Cascade)
  comentario_pai Comentario?  @relation("Respostas", fields: [id_comentario_pai], references: [id], onDelete: Cascade)
  respostas      Comentario[] @relation("Respostas")

  @@index([id_post, created_at(sort: Desc)])
  @@index([id_autor])
  @@index([id_comentario_pai])
  @@map("comentarios")
}

model Story {
  id          String   @id @default(cuid())
  id_autor    String
  midia_url   String
  tipo_midia  TipoMidia @default(imagem)
  duracao     Int       @default(5)
  views_count Int       @default(0)
  expira_em   DateTime
  created_at  DateTime  @default(now())

  autor         User        @relation("StoriesDoUsuario", fields: [id_autor], references: [id], onDelete: Cascade)
  visualizacoes StoryView[]

  @@index([id_autor])
  @@index([expira_em])
  @@index([id_autor, expira_em])
  @@map("stories")
}

model StoryView {
  id         String   @id @default(cuid())
  id_usuario String
  id_story   String
  created_at DateTime @default(now())

  usuario User  @relation("ViewsDoUsuario", fields: [id_usuario], references: [id], onDelete: Cascade)
  story   Story @relation(fields: [id_story], references: [id], onDelete: Cascade)

  @@unique([id_usuario, id_story])
  @@index([id_story])
  @@map("story_views")
}
